# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Replicate Configuration
REPLICATE_API_TOKEN=your-replicate-token-here

# Instagram (Optional)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
INSTAGRAM_GRAPH_ACCESS_TOKEN=your_graph_access_token
INSTAGRAM_GRAPH_IG_USER_ID=
INSTAGRAM_GRAPH_APP_ID=your_instagram_app_id
INSTAGRAM_GRAPH_APP_SECRET=your_instagram_app_secret
INSTAGRAM_GRAPH_PUBLIC_BASE_URL=https://your-public-domain-or-ip
INSTAGRAM_GRAPH_API_VERSION=v21.0
PUBLISH_TO_INSTAGRAM=false

# Scheduler Configuration
DAILY_CRON=0 9 */2 * *
TIMEZONE=America/Santiago

# Paths
IDENTITY_PACK_PATH=/identity_pack
DATA_PATH=/data

# Database
DATABASE_URL=sqlite:///./data/influencer.db

